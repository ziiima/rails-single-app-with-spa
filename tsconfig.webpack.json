{
    "compilerOptions": {
      "module": "ES2015",
      "target": "ES2015",
      "sourceMap": true,
      "jsx": "react-jsx",
      "lib": ["ES2023","DOM"],
      "moduleResolution": "bundler",
      "isolatedModules": true,
      "moduleDetection": "force",
  
      /* Linting */
      "strict": true,
      "noUnusedLocals": true,
      "noUnusedParameters": true,
      "noFallthroughCasesInSwitch": true,
      "noUncheckedSideEffectImports": true,
      "noImplicitAny": true,
    },
    "include": ["frontend"],
  }
  